# Agent Service
AGENT_API_KEY=dev-token
DATABASE_URL=sqlite+aiosqlite:///./data/mentor.db

# Provider Configuration (YAML-based — see providers.yaml)
# PROVIDERS_YAML_PATH=./providers.yaml  # Optional: defaults to ./providers.yaml
#
# MIGRATION NOTE: LITELLM_* env vars are NO LONGER SUPPORTED.
# All provider configuration must be in providers.yaml.
# See providers.yaml for format and examples.

# Provider API Keys (referenced via ${ENV_VAR} in providers.yaml)
# Only uncomment keys for API-based providers:
# NVIDIA_NIM_API_KEY=your-nvidia-nim-key

# Unified Proxy (standalone OCI VM service — https://github.com/blue126/unified-proxy)
# OAuth for Anthropic + OpenAI is handled by the proxy; only these two vars are needed here.
UNIFIED_PROXY_BASE_URL=https://proxy.yourdomain.com/v1
UNIFIED_PROXY_API_KEY=your-proxy-api-key

# Open WebUI (RAG Retrieval)
OPENWEBUI_BASE_URL=http://open-webui:8080
OPENWEBUI_API_KEY=your-openwebui-api-key
# Comma-separated default collection IDs for RAG search
OPENWEBUI_DEFAULT_COLLECTION_NAMES=

# Notion Integration (Optional)
NOTION_TOKEN=
NOTION_DB_ID=

# Mentor Persona
SYSTEM_PROMPT_PATH=app/prompts/mentor_system_prompt.md
MENTOR_MODE_ENABLED=true

# Agent Tool Use
MAX_TOOL_ITERATIONS=10
SSE_HEARTBEAT_INTERVAL=15

# AnkiConnect (Optional)
ANKI_CONNECT_URL=http://anki:8765
