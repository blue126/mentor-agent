# Agent Service
AGENT_API_KEY=your-bearer-token-here
DATABASE_URL=sqlite+aiosqlite:///./data/mentor.db

# Docker Compose 挂载路径（仅 compose 使用，app 不读取）
CLAUDE_CREDENTIALS_DIR=~/.claude
CLAUDE_AUTH_PATH=~/.claude

# LLM Provider (Cloud LLM Access)
# 基线（subscription profile）：claude-max-proxy:3456
# 回退（api profile）：https://api.anthropic.com
# LITELLM_* 前缀为历史命名，中性化重命名列入 P2 计划
LITELLM_BASE_URL=http://claude-max-proxy:3456/v1
LITELLM_KEY=your-provider-key
LITELLM_MODEL=sonnet

# Fallback profile (docker compose --profile fallback) 需要以下变量：
# CLAUDE_TOKEN=your-claude-token   # litellm-claude-code 容器使用，见 docker-compose.yml:54

# Open WebUI (RAG Retrieval)
OPENWEBUI_BASE_URL=http://open-webui:8080
OPENWEBUI_API_KEY=your-openwebui-api-key
# Comma-separated default collection IDs for RAG search (leave empty to require LLM to call list_knowledge_bases first)
OPENWEBUI_DEFAULT_COLLECTION_NAMES=

# Notion Integration (Optional)
NOTION_TOKEN=
NOTION_DB_ID=

# Mentor Persona
SYSTEM_PROMPT_PATH=app/prompts/mentor_system_prompt.md
MENTOR_MODE_ENABLED=true

# Agent Tool Use
MAX_TOOL_ITERATIONS=10
SSE_HEARTBEAT_INTERVAL=15

# AnkiConnect (Optional)
ANKI_CONNECT_URL=http://anki:8765
